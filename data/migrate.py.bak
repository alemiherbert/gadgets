#!/usr/bin/env python3
"""
Migrate scraped abanista.com data → Supabase + R2.

Steps:
  1. Reorganize 17 WC categories → 6 new categories + subcategories
  2. Convert all product images → WebP (quality=80, max 1200px)
  3. Rename with nanoid (8 chars)
  4. Upload to R2 via wrangler
  5. Clear old seed data from DB
  6. Insert brands, categories, subcategories, products, product_images, product_categories

Usage:
  cd data && source .venv/bin/activate
        python migrate.py                                # Auto-map existing WebP files + upload + DB
    python migrate.py --convert-images               # Rebuild WebP + image_map, then upload + DB
    python migrate.py --images-only                  # Image upload only (no DB)
        python migrate.py --db-only                      # DB only (uses existing image refs)
        python migrate.py --no-image-map                 # Ignore image_map.json and build from products
    python migrate.py --products-file abanista/tech_products_clean.json
    python migrate.py --image-map-file abanista/image_map.json
"""

import argparse
import json
import os
import re
import string
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
from io import BytesIO

from PIL import Image
import requests

# ── Paths ─────────────────────────────────────────────────
SCRIPT_DIR   = os.path.dirname(os.path.abspath(__file__))
ABANISTA_DIR = os.path.join(SCRIPT_DIR, "abanista")
WEBP_DIR     = os.path.join(ABANISTA_DIR, "images_webp")
PROJECT_ROOT = os.path.dirname(SCRIPT_DIR)

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL = "https://xplhaaslnrpaqqrpxkbm.supabase.co"
SUPABASE_KEY = os.environ.get("SUPABASE_SERVICE_ROLE_KEY", "")

# ── R2 ────────────────────────────────────────────────────
R2_BUCKET = "gadgets-images"

# ── Image config ──────────────────────────────────────────
WEBP_QUALITY = 80
MAX_WIDTH    = 1200
MAX_HEIGHT   = 1200
IMG_WORKERS  = 8
MAX_IMAGES_PER_PRODUCT = 6

# ── nanoid (custom, no deps) ─────────────────────────────
_NANOID_ALPHABET = string.ascii_lowercase + string.digits
def nanoid(size=8):
    import secrets
    return ''.join(secrets.choice(_NANOID_ALPHABET) for _ in range(size))


